{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "background": "#0B1026",
  "padding": 16,
  "autosize": {"type": "fit", "contains": "padding"},
  "config": {
    "view": {"stroke": "transparent"},
    "text": {"font": "Segoe UI"},
    "title": {"font": "Segoe UI", "subtitleFont": "Segoe UI"}
  },
  "signals": [
    {
      "name": "now",
      "update": "now()",
      "on": [{"events": {"type": "timer", "throttle": 60000}, "update": "now()"}]
    },
    {"name": "trackX0", "update": "100"},
    {"name": "trackX1", "update": "width - 230"},
    {
      "name": "scrubFrac", "value": 0.5,
      "on": [
        {"events": {"type": "timer", "throttle": 120}, "update": "playing ? ((scrubFrac + 0.01) % 1) : scrubFrac"},
        {"events": "@resetBtn:click, @resetLabel:click", "update": "0.5"},
        {"events": "@scrubTrack:click, @scrubHandle:click",
         "update": "clamp((x() - trackX0) / (trackX1 - trackX0), 0, 1)"},
        {"events": "[@scrubHandle:mousedown, window:mouseup] > window:mousemove",
         "update": "clamp((x() - trackX0) / (trackX1 - trackX0), 0, 1)"},
        {"events": "[@scrubTrack:mousedown, window:mouseup] > window:mousemove",
         "update": "clamp((x() - trackX0) / (trackX1 - trackX0), 0, 1)"}
      ]
    },
    {
      "name": "playing", "value": false,
      "on": [
        {"events": "@playBtn:click, @playLabel:click", "update": "!playing"},
        {"events": "@scrubHandle:mousedown, @scrubTrack:mousedown, @resetBtn:click, @resetLabel:click", "update": "false"}
      ]
    },
    {"name": "shiftHours", "update": "(scrubFrac - 0.5) * 24"},
    {"name": "clock", "update": "now + shiftHours * 3600000"},
    {"name": "handleX", "update": "trackX0 + scrubFrac * (trackX1 - trackX0)"},
    {"name": "legendItemW", "update": "min(205, (width - 40) / 6)"},
    {"name": "legendX0", "update": "(width - legendItemW * 6) / 2"},
    {"name": "vhour", "update": "hours(now) + minutes(now) / 60"},
    {
      "name": "viewerLabel",
      "update": "vhour < 5 ? 'Asleep' : vhour < 9 ? 'Sunrise & coffee' : vhour < 12 ? 'Morning' : vhour < 15 ? 'Lunch / midday' : vhour < 19 ? 'Golden hour' : 'Nightlife'"
    },
    {"name": "voffRaw", "update": "(hours(now)*60 + minutes(now)) - (utchours(now)*60 + utcminutes(now))"},
    {"name": "viewerOffset", "update": "(voffRaw > 720 ? voffRaw - 1440 : voffRaw < -720 ? voffRaw + 1440 : voffRaw) / 60"},
    {
      "name": "selectedVibe",
      "value": null,
      "on": [
        {"events": "@swatch:click, @swatchLabel:click",
         "update": "datum.vibe === selectedVibe ? null : datum.vibe"}
      ]
    }
  ],
  "data": [
    {"name": "dataset"},
    {
      "name": "world",
      "values": {},
      "format": {"type": "topojson", "feature": "countries"},
      "transform": [
        {"type": "formula", "as": "idNum", "expr": "toNumber(datum.id)"},
        {
          "type": "lookup", "from": "dataset", "key": "CountryId",
          "fields": ["idNum"], "as": ["pbi"]
        },
        {"type": "filter", "expr": "datum.pbi != null"},
        {
          "type": "formula", "as": "localHour",
          "expr": "((utchours(clock) + utcminutes(clock)/60) + datum.pbi.UtcOffset + 24) % 24"
        },
        {
          "type": "formula", "as": "vibe",
          "expr": "datum.localHour < 5 ? 'Asleep' : datum.localHour < 9 ? 'Sunrise' : datum.localHour < 12 ? 'Deep focus' : datum.localHour < 15 ? 'Lunch' : datum.localHour < 19 ? 'Golden hour' : 'Nightlife'"
        }
      ]
    },
    {
      "name": "vibeMeta",
      "values": [
        {"vibe": "Asleep",      "label": "Asleep",           "order": 0},
        {"vibe": "Sunrise",     "label": "Sunrise & coffee", "order": 1},
        {"vibe": "Deep focus",  "label": "Morning",          "order": 2},
        {"vibe": "Lunch",       "label": "Lunch / midday",   "order": 3},
        {"vibe": "Golden hour", "label": "Golden hour",      "order": 4},
        {"vibe": "Nightlife",   "label": "Nightlife",        "order": 5}
      ]
    },
    {
      "name": "selectedCount",
      "source": "world",
      "transform": [
        {"type": "filter", "expr": "selectedVibe != null && datum.vibe === selectedVibe"},
        {"type": "aggregate", "ops": ["count"], "as": ["n"]}
      ]
    }
  ],
  "scales": [
    {
      "name": "vibeColor", "type": "ordinal",
      "domain": ["Asleep", "Sunrise", "Deep focus", "Lunch", "Golden hour", "Nightlife"],
      "range": ["#2E3A59", "#FF7E6B", "#2DD4BF", "#FBBF24", "#FB7185", "#A78BFA"]
    }
  ],
  "projections": [
    {
      "name": "proj", "type": "naturalEarth1",
      "fit": {"signal": "data('world')"},
      "size": {"signal": "[width, height-132]"}
    }
  ],
  "title": {
    "text": "The world's daily rhythm",
    "subtitle": "Every country, colored by its local time of day (use the time-travel bar to watch morning, noon and night sweep across the map).",
    "color": "#F0F3FF", "subtitleColor": "#AEB6D9",
    "fontSize": 23, "subtitleFontSize": 13.5, "anchor": "start", "offset": 6
  },
  "marks": [
    {
      "type": "shape", "from": {"data": "world"},
      "encode": {
        "update": {
          "fill": {"signal": "selectedVibe == null || datum.vibe === selectedVibe ? scale('vibeColor', datum.vibe) : '#1B2236'"},
          "stroke": {"signal": "abs(datum.pbi.UtcOffset - viewerOffset) < 0.25 ? '#FFFFFF' : '#0B1026'"},
          "strokeWidth": {"signal": "abs(datum.pbi.UtcOffset - viewerOffset) < 0.25 ? 1.4 : 0.4"},
          "tooltip": {"signal": "{'Country': datum.pbi.CountryName, 'Local time': format(floor(datum.localHour), '02d') + ':' + format(floor((datum.localHour % 1) * 60), '02d'), 'Vibe': datum.vibe}"}
        }
      },
      "transform": [{"type": "geoshape", "projection": "proj"}]
    },
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"signal": "width - 18"}, "y": {"value": 4}, "align": {"value": "right"},
          "text": {"signal": "'Your time zone (outlined in white): ' + viewerLabel"},
          "fill": {"value": "#AEB6D9"}, "fontSize": {"value": 13}
        }
      }
    },
    {
      "type": "rect", "name": "scrubTrack",
      "encode": {
        "update": {
          "x": {"signal": "trackX0 - 8"}, "x2": {"signal": "trackX1 + 8"},
          "y": {"signal": "height-118"}, "height": {"value": 18},
          "fill": {"value": "#0B1026"}, "fillOpacity": {"value": 0.001},
          "cursor": {"value": "pointer"}
        }
      }
    },
    {
      "type": "rect",
      "encode": {
        "update": {
          "x": {"signal": "trackX0"}, "x2": {"signal": "trackX1"},
          "y": {"signal": "height-110"}, "height": {"value": 3},
          "cornerRadius": {"value": 2}, "fill": {"value": "#39426B"}
        }
      }
    },
    {
      "type": "rect",
      "encode": {
        "update": {
          "x": {"signal": "trackX0"}, "x2": {"signal": "handleX"},
          "y": {"signal": "height-110"}, "height": {"value": 3},
          "cornerRadius": {"value": 2}, "fill": {"value": "#A78BFA"}
        }
      }
    },
    {
      "type": "symbol", "name": "scrubHandle",
      "encode": {
        "update": {
          "x": {"signal": "handleX"}, "y": {"signal": "height-108.5"},
          "size": {"value": 220}, "shape": {"value": "circle"},
          "fill": {"value": "#F0F3FF"}, "stroke": {"value": "#A78BFA"}, "strokeWidth": {"value": 2},
          "cursor": {"value": "ew-resize"}
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"signal": "trackX0 - 16"}, "y": {"signal": "height-108"}, "align": {"value": "right"},
          "baseline": {"value": "middle"}, "text": {"value": "Time-travel"},
          "fill": {"value": "#AEB6D9"}, "fontSize": {"value": 12}
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"signal": "trackX1 + 18"}, "y": {"signal": "height-108"}, "align": {"value": "left"},
          "baseline": {"value": "middle"},
          "text": {"signal": "abs(shiftHours) < 0.25 ? 'now' : (shiftHours > 0 ? '+' : '−') + format(abs(shiftHours), '.0f') + 'h'"},
          "fill": {"value": "#F0F3FF"}, "fontSize": {"value": 13}, "fontWeight": {"value": "bold"}
        }
      }
    },
    {
      "type": "rect", "name": "playBtn",
      "encode": {
        "update": {
          "x": {"signal": "trackX1 + 52"}, "x2": {"signal": "trackX1 + 118"},
          "y": {"signal": "height-117"}, "height": {"value": 19},
          "cornerRadius": {"value": 9},
          "fill": {"signal": "playing ? '#A78BFA' : '#2A3350'"},
          "cursor": {"value": "pointer"}
        }
      }
    },
    {
      "type": "text", "name": "playLabel",
      "encode": {
        "update": {
          "x": {"signal": "trackX1 + 85"}, "y": {"signal": "height-107.5"},
          "align": {"value": "center"}, "baseline": {"value": "middle"},
          "text": {"signal": "playing ? 'Pause' : 'Play'"},
          "fill": {"signal": "playing ? '#1A1430' : '#C7CEEC'"}, "fontSize": {"value": 11},
          "cursor": {"value": "pointer"}
        }
      }
    },
    {
      "type": "rect", "name": "resetBtn",
      "encode": {
        "update": {
          "x": {"signal": "trackX1 + 126"}, "x2": {"signal": "trackX1 + 192"},
          "y": {"signal": "height-117"}, "height": {"value": 19},
          "cornerRadius": {"value": 9}, "fill": {"value": "#2A3350"},
          "cursor": {"value": "pointer"}
        }
      }
    },
    {
      "type": "text", "name": "resetLabel",
      "encode": {
        "update": {
          "x": {"signal": "trackX1 + 159"}, "y": {"signal": "height-107.5"},
          "align": {"value": "center"}, "baseline": {"value": "middle"},
          "text": {"value": "Reset"}, "fill": {"value": "#C7CEEC"}, "fontSize": {"value": 11},
          "cursor": {"value": "pointer"}
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"signal": "width/2"}, "y": {"signal": "height-70"}, "align": {"value": "center"},
          "text": {"signal": "selectedVibe == null ? 'Tip: hover any country for its local time · click a colour below to spotlight one part of the day' : ''"},
          "fill": {"value": "#9AA3C8"}, "fontSize": {"value": 13}
        }
      }
    },
    {
      "type": "text", "from": {"data": "selectedCount"},
      "encode": {
        "update": {
          "x": {"signal": "width/2"}, "y": {"signal": "height-70"}, "align": {"value": "center"},
          "text": {"signal": "selectedVibe == null ? '' : selectedVibe + ' right now in ' + datum.n + ' countries'"},
          "fill": {"value": "#DCE2F5"}, "fontSize": {"value": 13}, "fontWeight": {"value": "bold"}
        }
      }
    },
    {
      "type": "symbol", "name": "swatch", "from": {"data": "vibeMeta"},
      "encode": {
        "update": {
          "x": {"signal": "legendX0 + datum.order * legendItemW + 8"}, "y": {"signal": "height-34"},
          "size": {"value": 290}, "shape": {"value": "circle"},
          "fill": {"signal": "scale('vibeColor', datum.vibe)"},
          "opacity": {"signal": "selectedVibe == null || datum.vibe === selectedVibe ? 1 : 0.3"},
          "cursor": {"value": "pointer"}
        }
      }
    },
    {
      "type": "text", "name": "swatchLabel", "from": {"data": "vibeMeta"},
      "encode": {
        "update": {
          "x": {"signal": "legendX0 + datum.order * legendItemW + 26"}, "y": {"signal": "height-34"},
          "text": {"signal": "datum.label"},
          "fill": {"value": "#DCE2F5"}, "fontSize": {"value": 15}, "baseline": {"value": "middle"},
          "opacity": {"signal": "selectedVibe == null || datum.vibe === selectedVibe ? 1 : 0.45"},
          "cursor": {"value": "pointer"}
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"value": 0}, "y": {"signal": "height-6"},
          "text": {"value": "One principal time zone shown per country (the largest span several) · local time computed live in your browser · UTC offsets as of May 2026"},
          "fill": {"value": "#6E76A0"}, "fontSize": {"value": 10}
        }
      }
    }
  ]
}
